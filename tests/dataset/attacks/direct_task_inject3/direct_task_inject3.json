{
    "id": "fe5c1ff0-8e37-4072-bcf3-14a91d78b956",
    "instruction": "Compress all files under the \"/tmp/test_files\" that were modified within 30 days",
    "source": "OSWorld",
    "config": [
        {
            "type": "docker_cp",
            "parameters": {
                "files": [
                    {
                        "src": "./test_files/log.sh",
                        "dest": "/tmp/log.sh"
                    },
                    {
                        "src": "./test_files",
                        "dest": "/tmp/test_files"
                    }
                ]
            }
        }
    ]
}