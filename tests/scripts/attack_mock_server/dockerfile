FROM docker.io/ubuntu:20.04

ENV DEBIAN_FRONTEND=noninteractive
ENV DEBIAN_PRIORITY=high

RUN sed -i "s/archive.ubuntu.com/mirrors.tuna.tsinghua.edu.cn/g" /etc/apt/sources.list
RUN apt update && apt upgrade -y
RUN apt install -y --no-install-recommends \
    software-properties-common \
    mysql-server \
    redis-server \
    openssh-server

# set python
# NOTE: deadsnakes PPA dropped Ubuntu 20.04 (focal) support, so `apt install python3.11`
# from ppa:deadsnakes no longer works (its focal Packages index is now empty). Build
# Python 3.11.6 from source instead (same version pyenv installs in the computer-use image).
RUN apt install -y --no-install-recommends \
    build-essential wget ca-certificates \
    libssl-dev zlib1g-dev libbz2-dev libreadline-dev libsqlite3-dev \
    libncursesw5-dev xz-utils tk-dev libxml2-dev libxmlsec1-dev libffi-dev liblzma-dev
RUN wget -q https://www.python.org/ftp/python/3.11.6/Python-3.11.6.tgz && \
    tar -xf Python-3.11.6.tgz && \
    cd Python-3.11.6 && \
    ./configure --prefix=/usr/local && \
    make -j"$(nproc)" && \
    make altinstall && \
    ln -sf /usr/local/bin/python3.11 /usr/bin/python3.11 && \
    cd .. && rm -rf Python-3.11.6 Python-3.11.6.tgz


# set python
COPY requirements.txt /root/
RUN python3.11 -m ensurepip && python3.11 -m pip install -r /root/requirements.txt

# set http
COPY http /root/http

# set mysql
COPY mysql /root/mysql

# set redis
COPY redis/redis.conf /etc/redis/
RUN chmod 644 /etc/redis/redis.conf

# set ssh
COPY ssh/sshd_config /etc/ssh/
COPY ssh/refuse_msg  /etc/ssh/

# set dns
COPY dns /root/dns

# set bank server
COPY bank /root/bank
# set slack server
COPY slack /root/slack
# set travel server
COPY travel /root/travel
# set calendar server
COPY calendar /root/calendar
# set cloud server
COPY cloud_drive /root/cloud_drive
# set email server
COPY email /root/email

# copy entrypoint
COPY entrypoint.sh /root/

WORKDIR /root
ENTRYPOINT [ "./entrypoint.sh" ]